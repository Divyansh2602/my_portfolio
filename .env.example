# Contact form delivery (Resend). Without RESEND_API_KEY the API accepts
# submissions but logs instead of sending — handy for local dev.
RESEND_API_KEY=
# Verified sender on your Resend domain. Falls back to Resend's test sender.
CONTACT_FROM_EMAIL="DIVI://VOID <onboarding@resend.dev>"
# Where messages land.
CONTACT_TO_EMAIL=divyansh.gupta2023@vitstudent.ac.in

# Canonical site origin (used for metadata, OG, sitemap, robots). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: distributed rate limiting (Upstash Redis). If unset, the contact
# API falls back to a per-instance in-memory limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
